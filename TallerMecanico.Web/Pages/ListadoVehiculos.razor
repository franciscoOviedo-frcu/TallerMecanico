@page "/vehiculos"
@inject HttpClient Http
@using System.ComponentModel.DataAnnotations

<PageTitle>Listado de Vehículos</PageTitle>

<h1>Listado de Vehículos</h1>

<hr />

<div class="mb-3">
    <a href="/vehiculos/nuevo" class="btn btn-primary">
        <span class="oi oi-plus" aria-hidden="true"></span> Agregar Nuevo Vehículo
    </a>
</div>

<hr />

@if (vehiculos == null || clientes == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Patente</th>
                <th>Marca</th>
                <th>Modelo</th>
                <th>Año</th>
                <th>Propietario</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vehiculo in vehiculos)
            {
                <tr>
                    <td>@vehiculo.Patente</td>
                    <td>@vehiculo.Marca</td>
                    <td>@vehiculo.Modelo</td>
                    <td>@vehiculo.Anio</td>
                    <td>@GetNombreCliente(vehiculo.ClienteId)</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // --- DTOs (Modelos del Frontend) ---
    private class VehiculoDto
    {
        public int Id { get; set; }
        public string Patente { get; set; }
        public string Marca { get; set; }
        public string Modelo { get; set; }
        public int Anio { get; set; }
        public int ClienteId { get; set; } // La clave foránea
    }

    // (Podríamos mover esto a un archivo compartido, pero por ahora está bien aquí)
    private class ClienteDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; }
        public string Apellido { get; set; }
    }

    // --- Variables ---
    private VehiculoDto[] vehiculos;
    private ClienteDto[] clientes; // ¡Necesitamos la lista de clientes!

    // (Usa el puerto de TU API, el 7053 lo vimos la última vez)
    private string apiUrlVehiculos = "https://localhost:7053/api/Vehiculos";
    private string apiUrlClientes = "https://localhost:7053/api/Clientes";

    // --- Métodos ---

    // 1. Al cargar la página, cargamos AMBAS listas
    protected override async Task OnInitializedAsync()
    {
        try
        {
            vehiculos = await Http.GetFromJsonAsync<VehiculoDto[]>(apiUrlVehiculos);
            clientes = await Http.GetFromJsonAsync<ClienteDto[]>(apiUrlClientes);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
    }

    // 2. Función "Helper" para buscar el nombre del cliente
    private string GetNombreCliente(int clienteId)
    {
        if (clientes == null) return "Cargando...";

        var cliente = clientes.FirstOrDefault(c => c.Id == clienteId);
        return cliente != null ? $"{cliente.Nombre} {cliente.Apellido}" : "Cliente no encontrado";
    }
}
