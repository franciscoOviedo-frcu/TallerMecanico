@page "/vehiculos/nuevo"
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using System.ComponentModel.DataAnnotations

<PageTitle>Agregar Vehículo</PageTitle>

<h1>Agregar Nuevo Vehículo</h1>

<EditForm Model="@nuevoVehiculo" OnValidSubmit="HandleFormSubmit">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Propietario (Cliente):</label>
        <InputSelect class="form-select" @bind-Value="nuevoVehiculo.ClienteId">
            <option value="0">-- Seleccione un cliente --</option>
            @if (clientes != null)
            {
                @foreach (var cliente in clientes)
                {
                    <option value="@cliente.Id">@cliente.Nombre @cliente.Apellido</option>
                }
            }
        </InputSelect>
        <ValidationMessage For="@(() => nuevoVehiculo.ClienteId)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Patente:</label>
        <InputText class="form-control" @bind-Value="nuevoVehiculo.Patente" />
        <ValidationMessage For="@(() => nuevoVehiculo.Patente)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Marca:</label>
        <InputText class="form-control" @bind-Value="nuevoVehiculo.Marca" />
        <ValidationMessage For="@(() => nuevoVehiculo.Marca)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Modelo:</label>
        <InputText class="form-control" @bind-Value="nuevoVehiculo.Modelo" />
        <ValidationMessage For="@(() => nuevoVehiculo.Modelo)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Año:</label>
        <InputNumber class="form-control" @bind-Value="nuevoVehiculo.Anio" />
        <ValidationMessage For="@(() => nuevoVehiculo.Anio)" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar Vehículo</button>
    <a href="/vehiculos" class="btn btn-secondary">Cancelar</a>
</EditForm>


@code {
    // --- DTOs (Copiamos las definiciones aquí) ---
    // (En un proyecto más grande, esto estaría en un archivo .cs compartido)
    private class VehiculoDto
    {
        public int Id { get; set; }
        [Required(ErrorMessage = "La patente es obligatoria")]
        public string Patente { get; set; }
        [Required(ErrorMessage = "La marca es obligatoria")]
        public string Marca { get; set; }
        [Required(ErrorMessage = "El modelo es obligatorio")]
        public string Modelo { get; set; }
        [Range(1900, 2026, ErrorMessage = "El año debe ser válido")]
        public int Anio { get; set; } = DateTime.Now.Year;
        [Required(ErrorMessage = "Debe seleccionar un cliente")]
        [Range(1, int.MaxValue, ErrorMessage = "Debe seleccionar un cliente válido")]
        public int ClienteId { get; set; }
    }

    private class ClienteDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; }
        public string Apellido { get; set; }
    }

    // --- Variables ---
    private ClienteDto[] clientes; // Para el dropdown
    private VehiculoDto nuevoVehiculo = new VehiculoDto(); // Para el formulario

    // (Asegúrate de que el puerto 7053 sea el de tu API)
    private string apiUrlVehiculos = "https://localhost:7053/api/Vehiculos";
    private string apiUrlClientes = "https://localhost:7053/api/Clientes";

    // --- Métodos ---

    // 1. Al cargar la página, solo necesitamos la lista de Clientes
    protected override async Task OnInitializedAsync()
    {
        try
        {
            clientes = await Http.GetFromJsonAsync<ClienteDto[]>(apiUrlClientes);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al obtener clientes: {ex.Message}");
        }
    }

    // 2. Método para guardar el formulario (POST)
    private async Task HandleFormSubmit()
    {
        try
        {
            var response = await Http.PostAsJsonAsync(apiUrlVehiculos, nuevoVehiculo);

            if (response.IsSuccessStatusCode)
            {
                // ¡Éxito! Navegamos de vuelta a la lista
                NavigationManager.NavigateTo("/vehiculos");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al crear vehículo: {ex.Message}");
        }
    }
}